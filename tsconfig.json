{
  /**
   * TypeScript configuration for VWS FollowUp.
   *
   * Uses strict mode across the board to catch type errors early.
   * Path aliases are configured to match Next.js conventions and
   * keep imports clean throughout the codebase.
   */
  "compilerOptions": {
    // Language and type checking
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    // Module resolution
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",

    // Next.js
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],

    // Path aliases — keep imports short and consistent
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/features/*": ["./src/features/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/server/*": ["./src/server/*"],
      "@/types/*": ["./src/types/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
