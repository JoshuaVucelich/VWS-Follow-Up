# Required
DATABASE_URL="postgresql://postgres:password@localhost:5432/vws_followup?schema=public"
AUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional application branding
NEXT_PUBLIC_APP_NAME="VWS FollowUp"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional SMTP (password reset emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="VWS FollowUp <noreply@example.com>"
SMTP_SECURE="true"

# Optional QuickBooks integration
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_ENVIRONMENT="sandbox"
QUICKBOOKS_OAUTH_SCOPE="com.intuit.quickbooks.accounting"
